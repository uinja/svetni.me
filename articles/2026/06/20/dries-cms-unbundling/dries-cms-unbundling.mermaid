flowchart TB
    subgraph Planes ["РАЗГЛОБЯВАНЕТО: Управление срещу Изпълнение"]
        direction LR
        subgraph CP ["НИВО НА УПРАВЛЕНИЕ (Control Plane)"]
            direction TB
            cp1["Сигурност и Одобрения"]
            cp2["Права и Версии"]
            cp3["Дълготрайна структура"]
        end
        subgraph EP ["НИВО НА ИЗПЪЛНЕНИЕ (Execution Plane)"]
            direction TB
            ep1["ИИ Генерация и Дизайн"]
            ep2["Бързо сглобяване"]
            ep3["Разходи клонят към 0"]
        end
        EP -.->|ИИ комодитизира изпълнението| CP
    end

    subgraph Matrix ["МАТРИЦА НА РЕШЕНИЯТА"]
        direction TB
        subgraph Systems1 ["Една система"]
            Q1["ASSIST (1 човек)<br/>• Бърз прототип с ИИ (Lovable)<br/>• CMS за структуриране във времето"]
            Q2["RELAY (Много хора)<br/>• Колаборация и работни потоци<br/>• Ускорение на процесите с ИИ"]
        end
        subgraph SystemsMany ["Много системи"]
            Q3["DELEGATE (1 човек)<br/>• Автоматизация през API (n8n)<br/>• ИИ агенти вършат работата"]
            Q4["ORCHESTRATE (Много хора)<br/>• Сложни корпоративни процеси<br/>• CMS е защитената основа"]
        end
    end

    CP ==>|Стойността се измества към контрола| Matrix

    classDef default fill:#f8f9fa,stroke:#1a30ae,stroke-width:1px,color:#202124;
    classDef highlight fill:#1a30ae,stroke:#1a30ae,color:#ffffff;
    class CP,Matrix,Planes highlight;
