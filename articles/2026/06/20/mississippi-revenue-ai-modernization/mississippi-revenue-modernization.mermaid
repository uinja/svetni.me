graph TD
    subgraph Legacy ["Стара ИТ среда"]
        VMware["VMware Hypervisor"]
        HighCost["Високи лицензионни разходи"] --> VMware
    end

    subgraph Modernized ["Модернизирана платформа"]
        OpenShift["Red Hat OpenShift (Контейнерен хостинг)"]
        Portworx["Portworx (Сторидж слой)"]
        Everpure["Everpure Fusion (Контролен панел)"]

        OpenShift <--> Portworx
        Everpure -.-> |"Контроли и политики"| OpenShift
    end

    subgraph Guardrails ["Защитни механизми"]
        Snapshots["Неизменяеми моментни снимки"]
        Replication["Репликация на данни"]
        Provisioning["Стандартизирано заделяне"]
    end

    subgraph Outcomes ["Ползи за ведомството"]
        JuniorDevs["Безопасно обучение на младши кадри"]
        AIService["Сигурно внедряване на ИИ инструменти"]
        Fungibility["Преносимост (локална среда & облак)"]
    end

    VMware --> |"Миграция"| OpenShift
    Everpure --> Guardrails
    Guardrails --> JuniorDevs
    Guardrails --> AIService
    OpenShift --> Fungibility
