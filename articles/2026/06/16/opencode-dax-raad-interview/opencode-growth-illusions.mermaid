flowchart LR
    subgraph AIC["ИИ-ускорен цикъл (Фатална илюзия)"]
        direction TB
        A1["Бързо писане на код (ИИ агенти)"] --> A2["Лесно вкарване на хакове (Временни решения)"]
        A2 --> A3["Притъпяване на вината (Приглушена обратна връзка)"]
        A3 --> A4["Претоварване при прегледа (PR Burnout & Франкенщайн продукт)"]
        A4 --> A5["Технически дълг (Софтуерен разпад)"]
    end

    subgraph HE["Здрав инженерен подход (Устойчиво развитие)"]
        direction TB
        H1["Продуктово въздържание (Обмисляне на нуждите)"] --> H2["Почистване и рефакториране (Премахване на дълг)"]
        H2 --> H3["Силни обратни връзки (Директен контакт с болката)"]
        H3 --> H4["Високо софтуерно качество (Стабилност)"]
    end

    AIC -.->|"Сблъсък на принципите"| HE
